{
  "name": "datadog-export-checkly-migration",
  "version": "1.0.0",
  "description": "Export Datadog synthetics and global variables for migration to Checkly",
  "type": "module",
  "main": "src/01-initial-datadog-export.ts",
  "scripts": {
    "export": "node --import jiti/register src/01-initial-datadog-export.ts",
    "convert:api": "node --import jiti/register src/02-convert-datadog-api-to-json.ts",
    "filter-multi": "node --import jiti/register src/03-filter-multi-step-from-api-json.ts",
    "generate:checkly": "node --import jiti/register src/04-generate-api-check-constructs-from-json.ts",
    "migrate:api": "npm run convert:api && npm run generate:checkly",
    "generate:multi-specs": "node --import jiti/register src/05-generate-multi-step-specs.ts",
    "generate:multi-checks": "node --import jiti/register src/06-generate-multi-step-constructs.ts",
    "migrate:multi": "npm run generate:multi-specs && npm run generate:multi-checks",
    "generate:browser-specs": "node --import jiti/register src/07-generate-browser-specs.ts",
    "generate:browser-checks": "node --import jiti/register src/08-generate-browser-constructs.ts",
    "migrate:browser": "npm run generate:browser-specs && npm run generate:browser-checks",
    "convert:variables": "node --import jiti/register src/09-convert-global-variables.ts",
    "add:defaults": "node --import jiti/register src/10-add-default-resources.ts",
    "check:status": "node --import jiti/register src/10a-check-datadog-test-status.ts",
    "check:secrets": "node --import jiti/register src/10b-deactivate-missing-secrets.ts",
    "generate:groups": "node --import jiti/register src/11-generate-groups.ts",
    "generate:report": "node --import jiti/register src/12-generate-migration-report.ts",
    "migrate:all": "npm run export && npm run filter-multi && npm run migrate:api && npm run migrate:multi && npm run migrate:browser && npm run convert:variables && npm run generate:groups && npm run add:defaults && npm run check:status && npm run check:secrets && npm run generate:report"
  },
  "keywords": [
    "datadog",
    "checkly",
    "synthetics",
    "migration"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "dotenv": "^17.2.3"
  },
  "devDependencies": {
    "@types/node": "^25.0.9",
    "checkly": "^7.12.0",
    "jiti": "^2.6.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
